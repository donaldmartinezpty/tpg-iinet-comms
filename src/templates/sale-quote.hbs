{{> header title=(concat "Your " brand.displayName " quote")}}

<tr>
  <td style="padding: 20px 15px;">
    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
      <tr>
        <td style="font-family: Arial, Helvetica, sans-serif; font-size: 16px; line-height: 24px; color: {{brand.colors.text}}; padding-bottom: 20px;">
          <strong>Here’s your quote</strong>
        </td>
      </tr>
      <tr>
        <td style="font-family: Arial, Helvetica, sans-serif; font-size: 16px; line-height: 24px; color: {{brand.colors.text}}; padding-bottom: 20px;">
          Hi %%NAME%%,
        </td>
      </tr>
      <tr>
        <td style="font-family: Arial, Helvetica, sans-serif; font-size: 16px; line-height: 24px; color: {{brand.colors.text}}; padding-bottom: 20px;">
          We’ve attached the quote you requested. Please keep this handy as you may need to reference it during our next conversation.
        </td>
      </tr>
      <tr>
        <td style="font-family: Arial, Helvetica, sans-serif; font-size: 16px; line-height: 24px; color: {{brand.colors.text}}; padding-bottom: 20px;">
          <strong>Quote number</strong><br />%%QUOTE_NUMBER%%
        </td>
      </tr>
      <tr>
        <td style="font-family: Arial, Helvetica, sans-serif; font-size: 16px; line-height: 24px; color: {{brand.colors.text}}; padding-bottom: 20px;">
          Prices provided are based on what was discussed with you today. Please note that until you make a purchase, our prices are for indicative purposes only and may vary.
        </td>
      </tr>
      <tr>
        <td style="padding-bottom: 20px;">
          <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
            <tr>
              <td width="56" valign="top" style="padding: 0 16px 16px 0;">
                <img src="{{brand.quoteIcons.document}}" alt="" width="40" height="40" style="display: block;">
              </td>
              <td valign="top" style="font-family: Arial, Helvetica, sans-serif; font-size: 16px; line-height: 24px; color: {{brand.colors.text}}; padding-bottom: 16px;">
                If you are having problems opening this file, please download the latest version of Adobe Acrobat Reader.
              </td>
            </tr>
            <tr>
              <td width="56" valign="top" style="padding: 0 16px 16px 0;">
                <img src="{{brand.quoteIcons.headset}}" alt="" width="40" height="40" style="display: block;">
              </td>
              <td valign="top" style="font-family: Arial, Helvetica, sans-serif; font-size: 16px; line-height: 24px; color: {{brand.colors.text}}; padding-bottom: 16px;">
                Please don’t reply to this email as the mailbox is not monitored. If you have any questions about your quote, please call us on {{brand.support.phone}} and we’ll be happy to help.
              </td>
            </tr>
            <tr>
              <td width="56" valign="top" style="padding: 0 16px 0 0;">
                <img src="{{brand.quoteIcons.info}}" alt="" width="40" height="40" style="display: block;">
              </td>
              <td valign="top" style="font-family: Arial, Helvetica, sans-serif; font-size: 16px; line-height: 24px; color: {{brand.colors.text}};">
                You can find the terms and conditions for our products at: {{brand.termsUrl}}
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </td>
</tr>

<tr>
  <td style="padding: 20px 15px 60px;">
    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
      <tr>
        <td style="font-family: Arial, Helvetica, sans-serif; font-size: 16px; line-height: 24px; color: {{brand.colors.text}};">
          Thanks,<br>
          Your {{brand.displayName}} Team
        </td>
      </tr>
    </table>
  </td>
</tr>

{{> footer}}
